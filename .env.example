# Copy to .env for local dev (never commit .env — repo is public).

INGEST_SECRET=change-me-local-only

# Optional: leave empty to run API without a database (stub responses only).
DATABASE_URL=postgresql://ianbot:ianbot@localhost:5432/ianbot

GEMINI_ENABLED=false
# studio (AI Studio): GEMINI_BACKEND=studio + GEMINI_API_KEY
# vertex (prod): GEMINI_BACKEND=vertex + GOOGLE_CLOUD_PROJECT/LOCATION (no API key)
GEMINI_BACKEND=studio
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Vertex AI (when GEMINI_BACKEND=vertex): enable API + billing; SA needs Vertex AI User role.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Drive auth: auto (default) uses credentials file if set, else gcloud ADC.
# file = require GOOGLE_APPLICATION_CREDENTIALS (SA key or WIF config JSON)
# adc  = gcloud auth application-default login (no key file)
DRIVE_AUTH=auto
# Local POC only: on Drive ADC 403, retry with GOOGLE_APPLICATION_CREDENTIALS SA file.
# Never enable in production/GKE.
DRIVE_DEBUG_SA_FALLBACK=false
# Phase 0 — Drive download (in-memory only; never commit keys):
GOOGLE_APPLICATION_CREDENTIALS=
# DRIVE_FOLDER_ID=   # optional; for folder listing / future checks
# SHEET_ID=

# Bot webhooks (A1): comma-separated enabled platforms
BOT_PLATFORMS=slack,telegram
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Group-only: comma-separated negative chat IDs (supergroups). DMs are ignored.
TELEGRAM_ALLOWED_CHAT_IDS=
# Without @; required for @mention gating in allowed groups (e.g. legallywon_bot).
TELEGRAM_BOT_USERNAME=
