# Copy to .env for local dev (never commit .env — repo is public).

INGEST_SECRET=change-me-local-only

# Optional: leave empty to run API without a database (stub responses only).
DATABASE_URL=postgresql://wonbot:wonbot@localhost:5432/wonbot

# API key from ian@initia.xyz, to test using Gemini locally (not Vertex)
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_BACKEND=vertex
GEMINI_MODEL=gemini-2.5-flash-lite

# Vertex AI (when GEMINI_BACKEND=vertex): enable API + billing; SA needs Vertex AI User role.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Drive + Vertex: gcloud ADC (gcloud auth application-default login)
DRIVE_AUTH=adc
DRIVE_DEBUG_SA_FALLBACK=yes
GOOGLE_APPLICATION_CREDENTIALS=
DRIVE_FOLDER_ID=
# SHEET_ID=
# ianbot-ingest@exp-bizint-dashboard.iam.gserviceaccount.com

# Bot webhooks (A1): comma-separated enabled platforms
BOT_PLATFORMS=slack,telegram
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Group-only: comma-separated negative chat IDs (supergroups). DMs are ignored.
TELEGRAM_ALLOWED_CHAT_IDS=
# Without @; required for @mention gating in allowed groups (e.g. legallywon_bot).
TELEGRAM_BOT_USERNAME=

# FAQ layer (A1.5): rapidfuzz matching against bot/content/faqs.yaml
BOT_FAQ_ENABLED=true
BOT_FAQ_PATH=bot/content/faqs.yaml
BOT_FAQ_MIN_SCORE=70
# Debug sink: second message with handler + fuzzy stats (user reply unchanged).
BOT_DEBUG_ENABLED=false
# Optional Telegram chat id for debug text (e.g. your user id or a dev group).
TELEGRAM_DEBUG_CHAT_ID=
# Slack: set channel id to post debug there; leave empty to reply in-thread on Slack events.
SLACK_DEBUG_CHANNEL_ID=

# Local dev: long-poll getUpdates instead of webhook (reliable when ngrok drops Telegram traffic)
BOT_TELEGRAM_USE_POLLING=true
